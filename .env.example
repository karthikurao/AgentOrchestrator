# LLM provider: github | nvidia
LLM_PROVIDER=github

# GitHub token for GitHub Models API (when LLM_PROVIDER=github)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# NVIDIA API key (when LLM_PROVIDER=nvidia)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Model configuration
MODEL_NAME=gpt-4o
API_BASE_URL=https://models.inference.ai.azure.com
TOP_P=1.0

# Agent settings
MAX_TOKENS=4096
TEMPERATURE=0.3
VERBOSE=false
