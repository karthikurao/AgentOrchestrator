# GitHub Token for GitHub Models API (GitHub Copilot)
# Get your token from: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Model configuration
MODEL_NAME=gpt-4o
API_BASE_URL=https://models.inference.ai.azure.com

# Agent settings
MAX_TOKENS=4096
TEMPERATURE=0.3
VERBOSE=false
